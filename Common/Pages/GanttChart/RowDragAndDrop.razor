@page "/gantt-chart/row-drag-and-drop"

@using Syncfusion.Blazor.Gantt
@using BlazorDemos.Pages.GanttChart.Data

@*Hidden:Lines*@
@inject SampleService SampleService
@implements IDisposable
@*End:Hidden*@

<ActionDescription>
    <p>
		This sample demonstrates the row drag and drop feature in the <a class="e-gantt-rowdraganddrop-reference-link" aria-label="Navigate to the explore Syncfusion Blazor Gantt Chart component"
                                                                         href="https://www.syncfusion.com/blazor-components/blazor-gantt-chart"
                                                                         target="_blank" rel="noopener">Blazor Gantt Chart</a>. It allows tasks to be repositioned within the gantt chart by dragging a row and dropping it either above or below another row as a sibling, or as a child under a parent task.
    </p>

    <p>
		To enable this functionality, set the <a class="e-gantt-rowdraganddrop-reference-link" aria-label="Navigate to the AllowRowDragAndDrop property reference for gantt chart component" target="_blank" rel="noopener" href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.SfGantt-1.html#Syncfusion_Blazor_Gantt_SfGantt_1_AllowRowDragAndDrop">AllowRowDragAndDrop</a> property to <code>true</code>. This allows seamless reordering and restructuring of tasks directly within the gantt chart, based on the provided data source.
    </p>

    <p>
		For further details, refer to the <a class="e-gantt-rowdraganddrop-reference-link" aria-label="Navigate to the documentation for row drag and drop in gantt chart component" target="_blank" rel="noopener" href="https://blazor.syncfusion.com/documentation/gantt-chart/drag-and-drop">documentation</a>.
    </p>
</ActionDescription>

<div class="control-section e-gantt-rowDD-sample">
	<SfGantt @ref="GanttInstance" DataSource="@TaskCollection" Height="450px" Width="100%" HighlightWeekends="true" ProjectStartDate="@(new DateTime(2021, 3, 24))"
			 ProjectEndDate="@(new DateTime(2021, 7, 19))" TreeColumnIndex="1" AllowRowDragAndDrop="true" ScrollToTaskbarOnClick="true">
		<GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress"
						 Dependency="Predecessor" ParentID="ParentId"></GanttTaskFields>
		<GanttColumns>
			<GanttColumn Field="TaskId" Width="100"></GanttColumn>
			<GanttColumn Field="TaskName" Width="250" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip"></GanttColumn>
			<GanttColumn Field="StartDate" HeaderText="Start Date" MinWidth="120"></GanttColumn>
			<GanttColumn Field="EndDate" HeaderText="End Date" MinWidth="120"></GanttColumn>
			<GanttColumn Field="Duration" HeaderText="Duration" MinWidth="120"></GanttColumn>
			<GanttColumn Field="Progress" HeaderText="Progress" MinWidth="120"></GanttColumn>
			<GanttColumn Field="Predecessor" HeaderText="Dependency" MinWidth="200"></GanttColumn>
		</GanttColumns>
		<GanttLabelSettings LeftLabel="TaskName" TValue="GanttDefaultTaskData"></GanttLabelSettings>
		<GanttSplitterSettings Position="42%"></GanttSplitterSettings>
	</SfGantt>
</div>
@*Hidden:Lines*@
@code {
	protected override void OnInitialized()
	{
		SampleService.TouchMousePreferenceChanged += OnTouchMousePreferenceChanged;
	}

	private async void OnTouchMousePreferenceChanged()
	{
		if (GanttInstance == null)
		{
			return;
		}
		await GanttInstance.RefreshAsync();
		await GanttInstance.CallStateHasChangedAsync();
	}
#if WASM
	private bool _disposed;
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender || _disposed || GanttInstance == null)
		{
			return;
		}

		await Task.Delay(30);

		if (_disposed || GanttInstance == null)
		{
			return;
		}

		await GanttInstance.RefreshAsync().ConfigureAwait(true);
	}
#endif
	public void Dispose()
	{
#if WASM
		_disposed = true;
#endif
		SampleService.TouchMousePreferenceChanged -= OnTouchMousePreferenceChanged;
	}
}
<style>
	.container-fluid {
		padding: 0px !important;
	}
</style>
@*End:Hidden*@
