@page "/gantt-chart/holidays"

@using Syncfusion.Blazor.Gantt
@using BlazorDemos.Pages.GanttChart.Data

@*Hidden:Lines*@
@inject SampleService SampleService
@implements IDisposable
@*End:Hidden*@

<ActionDescription>
    <p>
		This sample demonstrates how the <a class="e-gantt-holiday-reference-link" aria-label="Navigate to the explore Syncfusion Blazor Gantt Chart component"
                                            href="https://www.syncfusion.com/blazor-components/blazor-gantt-chart"
                                            target="_blank" rel="noopener">Blazor Gantt Chart</a>
        highlights holidays within a project schedule. Vertical markers identify nonworking periods so timelines remain accurate and milestones stay visible even when work pauses.
    </p>

    <p>
        Holidays are declared through the
		<a class="e-gantt-holiday-reference-link" aria-label="Navigate to the class reference for Gantt holiday"
           href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.GanttHoliday.html"
           target="_blank" rel="noopener">GanttHoliday</a>
        collection. Use the
		<a class="e-gantt-holiday-reference-link" aria-label="Navigate to the label property reference for Gantt holiday"
           href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.GanttHoliday.html#Syncfusion_Blazor_Gantt_GanttHoliday_Label"
           target="_blank" rel="noopener">Label</a>
        property to display descriptive text beside each marker and specify
		<a class="e-gantt-holiday-reference-link" aria-label="Navigate to the From property reference for Gantt holiday"
           href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.GanttHoliday.html#Syncfusion_Blazor_Gantt_GanttHoliday_From"
           target="_blank" rel="noopener">From</a>
        and
		<a class="e-gantt-holiday-reference-link" aria-label="Navigate to the To property reference for Gantt holiday"
           href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.GanttHoliday.html#Syncfusion_Blazor_Gantt_GanttHoliday_To"
           target="_blank" rel="noopener">To</a>
        dates to describe continuous breaks such as long weekends or seasonal shutdowns. Any number of entries can be supplied to match the organizational calendar.
    </p>

    <p>
        Styling is customizable via the
		<a class="e-gantt-holiday-reference-link" aria-label="Navigate to the CssClass property reference for Gantt holiday"
           href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.GanttHoliday.html#Syncfusion_Blazor_Gantt_GanttHoliday_CssClass"
           target="_blank" rel="noopener">CssClass</a>
        property, allowing unique colors or decorations for each holiday so critical events stand out. 
    </p>
    <p>
        For further details, refer to the
		<a class="e-gantt-holiday-reference-link" aria-label="Navigate to the documentation for holidays in the Gantt chart component"
           href="https://blazor.syncfusion.com/documentation/gantt-chart/holidays/"
           target="_blank" rel="noopener">documentation</a>.
    </p>
</ActionDescription>

<div class="control-section e-gantt-holidays-sample">
	<SfGantt @ref="GanttInstance" DataSource="@TaskCollection" Height="450px" Width="100%" TreeColumnIndex="1"
			 ProjectStartDate="@(new DateTime(2021, 3, 28))" ProjectEndDate="@(new DateTime(2021, 7, 20))"
			 GridLines="GridLine.Vertical" HighlightWeekends="true" ScrollToTaskbarOnClick="true">
		<GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate"
						 EndDate="EndDate" Duration="Duration"
						 Progress="Progress" ParentID="ParentId"
						 Dependency="Predecessor">
		</GanttTaskFields>
		<GanttColumns>
			<GanttColumn Field="TaskId" Width="100"></GanttColumn>
			<GanttColumn Field="TaskName" HeaderText="Task Name"
						 Width="250" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip">
			</GanttColumn>
			<GanttColumn Field="StartDate" HeaderText="Start Date"></GanttColumn>
			<GanttColumn Field="EndDate" HeaderText="End Date"></GanttColumn>
			<GanttColumn Field="Duration" HeaderText="Duration"></GanttColumn>
			<GanttColumn Field="Progress" HeaderText="Progress"></GanttColumn>
			<GanttColumn Field="Predecessor" HeaderText="Dependency"></GanttColumn>
		</GanttColumns>
		<GanttHolidays>
			@foreach (HolidayModel holiday in HolidayCollection)
			{
				<GanttHoliday From="@holiday.HolidayDate" To="@holiday.HolidayDate" Label="@holiday.HolidayName"></GanttHoliday>
			}
		</GanttHolidays>
		<GanttLabelSettings RightLabel="TaskName" TValue="GanttDefaultTaskData"> </GanttLabelSettings>
		<GanttSplitterSettings Position="28%"></GanttSplitterSettings>
	</SfGantt>
</div>
@*Hidden:Lines*@
@code {
	private async void OnTouchMousePreferenceChanged()
	{
		if (GanttInstance == null)
		{
			return;
		}
		await GanttInstance.RefreshAsync();
		await GanttInstance.CallStateHasChangedAsync();
	}
#if WASM
	private bool _disposed;
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender || _disposed || GanttInstance == null)
		{
			return;
		}

		await Task.Delay(30);

		if (_disposed || GanttInstance == null)
		{
			return;
		}

		await GanttInstance.RefreshAsync().ConfigureAwait(true);
	}
#endif
	public void Dispose()
	{
#if WASM
		_disposed = true;
#endif
		SampleService.TouchMousePreferenceChanged -= OnTouchMousePreferenceChanged;
	}
}
<style>
	.container-fluid {
		padding: 0px !important;
	}
</style>
@*End:Hidden*@