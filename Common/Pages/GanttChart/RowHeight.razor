@page "/gantt-chart/row-height"

@using Syncfusion.Blazor.Gantt
@using Syncfusion.Blazor.Navigations
@using BlazorDemos.Pages.GanttChart.Data

@*Hidden:Lines*@
@inject SampleService SampleService
@implements IDisposable
@*End:Hidden*@

<ActionDescription>
    <p>
		This sample demonstrates how to customize the row height in the <a class="e-gantt-rowheight-reference-link" aria-label="Navigate to the explore Syncfusion Blazor Gantt Chart component"
                                                                           href="https://www.syncfusion.com/blazor-components/blazor-gantt-chart"
                                                                           target="_blank" rel="noopener">Blazor Gantt Chart</a>. Adjusting the row height allows for better control over the visual spacing of tasks, enhancing readability and layout flexibility.
    </p>

    <p>
		The row height can be modified by setting the desired pixel value using the <a class ="e-gantt-rowheight-reference-link" aria-label="Navigate to the row height property reference for gantt chart component" target="_blank" rel="noopener" href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.SfGantt-1.html#Syncfusion_Blazor_Gantt_SfGantt_1_RowHeight">RowHeight</a> property. In this example, the row height is configured during the initial load to showcase how tasks appear with increased spacing.
    </p>

    <p>
		For further details, refer to the <a class="e-gantt-rowheight-reference-link" aria-label="Navigate to the documentation for row height in gantt chart component" target="_blank" rel="noopener" href="https://blazor.syncfusion.com/documentation/gantt-chart/rows/#row-height">documentation</a>.
    </p>
</ActionDescription>

<div class="control-section e-gantt-row-height-sample">
	<SfGantt @ref="GanttInstance" DataSource="@TaskCollection" RowHeight="@CurrentRowHeight" Toolbar="ToolbarItems" Height="450px" TreeColumnIndex="1" Width="100%"
			 HighlightWeekends="true" ProjectStartDate="@(new DateTime(2021, 3, 24))" ProjectEndDate="@(new DateTime(2021, 7, 16))" ScrollToTaskbarOnClick="true">
		<GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress" ParentID="ParentId" Dependency="Predecessor">
		</GanttTaskFields>
		<GanttColumns>
			<GanttColumn Field="TaskId" Width="100"></GanttColumn>
			<GanttColumn Field="TaskName" Width="250" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip"></GanttColumn>
			<GanttColumn Field="StartDate" HeaderText="Start Date" MinWidth="120"></GanttColumn>
			<GanttColumn Field="EndDate" HeaderText="End Date" MinWidth="120"></GanttColumn>
			<GanttColumn Field="Duration" HeaderText="Duration" MinWidth="120"></GanttColumn>
			<GanttColumn Field="Progress" HeaderText="Progress" MinWidth="120"></GanttColumn>
			<GanttColumn Field="Predecessor" HeaderText="Dependency" MinWidth="200"></GanttColumn>
		</GanttColumns>
		<GanttLabelSettings LeftLabel="TaskName" TValue="GanttDefaultTaskData">
		</GanttLabelSettings>
		<GanttSplitterSettings Position="28%"></GanttSplitterSettings>
		<GanttEvents OnToolbarClick="OnToolbarClick" TValue="GanttDefaultTaskData"></GanttEvents>
	</SfGantt>
</div>
@*Hidden:Lines*@
@code{
	protected override void OnInitialized()
	{
		SampleService.TouchMousePreferenceChanged += OnTouchMousePreferenceChanged;
	}

	private async void OnTouchMousePreferenceChanged()
	{
		if (GanttInstance == null)
		{
			return;
		}
		await GanttInstance.RefreshAsync();
		await GanttInstance.CallStateHasChangedAsync();
	}
#if WASM
	private bool _disposed;
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender || _disposed || GanttInstance == null)
		{
			return;
		}

		await Task.Delay(30);

		if (_disposed || GanttInstance == null)
		{
			return;
		}

		await GanttInstance.RefreshAsync().ConfigureAwait(true);
	}
#endif
	public void Dispose()
	{
#if WASM
		_disposed = true;
#endif
		SampleService.TouchMousePreferenceChanged -= OnTouchMousePreferenceChanged;
	}
}
<style>
.container-fluid {
		padding: 0px !important;
	}
</style>
@*End:Hidden*@
 