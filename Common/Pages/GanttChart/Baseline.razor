@page "/gantt-chart/baseline"

@using Syncfusion.Blazor.Gantt
@using BlazorDemos.Pages.GanttChart.Data

@*Hidden:Lines*@
@inject SampleService SampleService
@implements IDisposable
@*End:Hidden*@

<ActionDescription>
    <p>
		This sample demonstrates a complete car service schedule using the <a class="e-gantt-baseline-reference-link" aria-label="Navigate to the explore Syncfusion Blazor Gantt Chart component"
                                                                              href="https://www.syncfusion.com/blazor-components/blazor-gantt-chart"
                                                                              target="_blank" rel="noopener">Blazor Gantt Chart</a>, highlighting how baselines can be used to compare planned and actual task dates.
    </p>
    <p>
		Baselines help track deviations between the original schedule and actual progress. In the Gantt Chart component, baselines can be enabled by setting the <a class="e-gantt-baseline-reference-link" aria-label="Navigate to the RenderBaseline property reference for gantt chart component" target="_blank" rel="noopener" href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.SfGantt-1.html#Syncfusion_Blazor_Gantt_SfGantt_1_RenderBaseline">RenderBaseline</a> property to <code>true</code>. Additionally, you must map the baseline data using the <a class="e-gantt-baseline-reference-link" aria-label="Navigate to the Baseline Start Date property reference for gantt task fields" target="_blank" rel="noopener" href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.GanttTaskFields.html#Syncfusion_Blazor_Gantt_GanttTaskFields_BaselineStartDate">BaselineStartDate</a> and <a class="e-gantt-baseline-reference-link" aria-label="Navigate to the BaselineEndDate property reference for gantt chart component" target="_blank" rel="noopener" href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.GanttTaskFields.html#Syncfusion_Blazor_Gantt_GanttTaskFields_BaselineEndDate">BaselineEndDate</a> properties within <a class="e-gantt-baseline-reference-link" aria-label="Navigate to the GanttTaskFields of Gantt Chart component" href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.GanttTaskFields.html" target="_blank" rel="noopener">GanttTaskFields</a>.
    </p>
    <p>
		Once configured, baselines are displayed for all task types including child tasks, parent tasks, and milestones providing a clear visual reference for schedule variance. You can customize the appearance of baselines using the <a class="e-gantt-baseline-reference-link" aria-label="Navigate to the Baseline Color property reference for gantt chart component" target="_blank" rel="noopener" href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.SfGantt-1.html#Syncfusion_Blazor_Gantt_SfGantt_1_BaselineColor">BaselineColor</a> property to match your project�s visual theme.
    </p>
    <p>
		For further details, refer to the <a class="e-gantt-baseline-reference-link" aria-label="Navigate to the documentation for baseline in gantt chart component" target="_blank" rel="noopener" href="https://blazor.syncfusion.com/documentation/gantt-chart/baseline">documentation</a>.
    </p>
</ActionDescription>

<div class="control-section e-gantt-baseline-sample">
	<SfGantt @ref="GanttInstance" DataSource="@TaskCollection" Height="450px" Width="100%" RowHeight="38" HighlightWeekends="true"
			 TreeColumnIndex="1" ProjectStartDate="@(new DateTime(2021, 3, 24))" ProjectEndDate="@(new DateTime(2021, 7, 6))" RenderBaseline="@IsBaselineVisible" Toolbar="@ToolbarItems">
		<GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate" Duration="Duration" Progress="Progress"
						 ParentID="ParentId" BaselineStartDate="BaselineStartDate" BaselineEndDate="BaselineEndDate">
		</GanttTaskFields>
		<GanttColumns>
			<GanttColumn Field="TaskId" HeaderText="Task Id"></GanttColumn>
			<GanttColumn Field="TaskName" HeaderText="Task Name" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip"></GanttColumn>
			<GanttColumn Field="StartDate" HeaderText="Start Date"></GanttColumn>
			<GanttColumn Field="EndDate" HeaderText="End Date"></GanttColumn>
			<GanttColumn Field="BaselineStartDate" HeaderText="Baseline Start Date" Width="200"></GanttColumn>
			<GanttColumn Field="BaselineEndDate" HeaderText="Baseline End Date" Width="200"></GanttColumn>
		</GanttColumns>
		<GanttLabelSettings LeftLabel="TaskName" TValue="BaseData.TaskData"></GanttLabelSettings>
		<GanttSplitterSettings Position="28%"></GanttSplitterSettings>
	</SfGantt>
</div>
@*Hidden:Lines*@
@code {
	protected override void OnInitialized()
	{
		if (SampleService != null) 
		{ 
			SampleService.TouchMousePreferenceChanged += OnTouchMousePreferenceChanged;
		}
	}
	private async void OnTouchMousePreferenceChanged()
	{
		if (GanttInstance == null)
		{
			return;
		}
		await GanttInstance.RefreshAsync();
		await GanttInstance.CallStateHasChangedAsync();
	}
#if WASM
	private bool _disposed;
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender || _disposed || GanttInstance == null)
		{
			return;
		}

		await Task.Delay(30);

		if (_disposed || GanttInstance == null)
		{
			return;
		}

		await GanttInstance.RefreshAsync().ConfigureAwait(true);
	}
#endif
	public void Dispose()
	{
#if WASM
		_disposed = true;
#endif
		SampleService.TouchMousePreferenceChanged -= OnTouchMousePreferenceChanged;
	}
}
<style>
	.container-fluid {
		padding: 0px !important;
	}
</style>
@*End:Hidden*@