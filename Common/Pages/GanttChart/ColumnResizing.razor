@page "/gantt-chart/column-resizing"

@using Syncfusion.Blazor.Gantt
@using BlazorDemos.Pages.GanttChart.Data

@*Hidden:Lines*@
@inject SampleService SampleService
@implements IDisposable
@*End:Hidden*@

<ActionDescription>
    <p>
		This sample demonstrates column resizing in the <a class="e-gantt-columnresizing-reference-link" aria-label="Navigate to the explore Syncfusion Blazor Gantt Chart component"
                                                           href="https://www.syncfusion.com/blazor-components/blazor-gantt-chart"
                                                           target="_blank" rel="noopener">Blazor Gantt Chart</a>.
        Drag the right edge of any column header to adjust its width and optimize the layout for task details that matter most.
    </p>

    <p>
        Enable column resizing by setting the
		<a class="e-gantt-columnresizing-reference-link" aria-label="Navigate to the AllowResizing property reference for the Gantt chart component"
           href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.SfGantt-1.html#Syncfusion_Blazor_Gantt_SfGantt_1_AllowResizing"
           target="_blank" rel="noopener">AllowResizing</a>
        property to <code>true</code>. Individual fields can be excluded from this behavior by setting
		<a class="e-gantt-columnresizing-reference-link" aria-label="Navigate to the AllowResizing property reference for Gantt column"
           href="https://help.syncfusion.com/cr/blazor/Syncfusion.Blazor.Gantt.GanttColumn.html#Syncfusion_Blazor_Gantt_GanttColumn_AllowResizing"
           target="_blank" rel="noopener">GanttColumn.AllowResizing</a>
        to <code>false</code> within the column definition. 
    </p>
    <p>
        For further details, refer to the
		<a class="e-gantt-columnresizing-reference-link" aria-label="Navigate to the documentation for column resizing in the Gantt chart component"
           href="https://blazor.syncfusion.com/documentation/gantt-chart/column-resizing"
           target="_blank" rel="noopener">documentation</a>.
    </p>
</ActionDescription>

<div class="control-section e-gantt-column-resizing-sample">
	<SfGantt @ref="GanttInstance" DataSource="@TaskCollection" Height="450px" Width="100%" AllowResizing="true" TreeColumnIndex="1" HighlightWeekends="true"
			 ProjectStartDate="@(new DateTime(2021, 3, 24))" ProjectEndDate="@(new DateTime(2021, 7, 18))" ScrollToTaskbarOnClick="true">
		<GanttTaskFields Id="TaskId" Name="TaskName" StartDate="StartDate" EndDate="EndDate"
						 Duration="Duration" Progress="Progress" ParentID="ParentId" Dependency="Predecessor">
		</GanttTaskFields>
		<GanttColumns>
			<GanttColumn Field="TaskId" Width="100"></GanttColumn>
			<GanttColumn Field="TaskName" Width="250" ClipMode="Syncfusion.Blazor.Grids.ClipMode.EllipsisWithTooltip"></GanttColumn>
			<GanttColumn Field="StartDate" HeaderText="Start Date" MinWidth="120"></GanttColumn>
			<GanttColumn Field="EndDate" HeaderText="End Date" MinWidth="120"></GanttColumn>
			<GanttColumn Field="Duration" HeaderText="Duration" MinWidth="120"></GanttColumn>
			<GanttColumn Field="Progress" HeaderText="Progress" MinWidth="120"></GanttColumn>
			<GanttColumn Field="Predecessor" HeaderText="Dependency" MinWidth="200"></GanttColumn>
		</GanttColumns>
		<GanttLabelSettings LeftLabel="TaskName" TValue="GanttDefaultTaskData"></GanttLabelSettings>
		<GanttSplitterSettings Position="55%"></GanttSplitterSettings>
	</SfGantt>
</div>

@*Hidden:Lines*@
@code {
	protected override void OnInitialized()
	{
		if (SampleService != null) 
		{ 
			SampleService.TouchMousePreferenceChanged += OnTouchMousePreferenceChanged;
		}
	}

	private async void OnTouchMousePreferenceChanged()
	{
		if (GanttInstance == null) return;
		await GanttInstance.RefreshAsync();
		await GanttInstance.CallStateHasChangedAsync();
	}
#if WASM
	private bool _disposed;
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender || _disposed || GanttInstance == null)
		{
			return;
		}

		await Task.Delay(30);

		if (_disposed || GanttInstance == null)
		{
			return;
		}

		await GanttInstance.RefreshAsync().ConfigureAwait(true);
	}
#endif
	public void Dispose()
	{
#if WASM
		_disposed = true;
#endif
		SampleService.TouchMousePreferenceChanged -= OnTouchMousePreferenceChanged;
	}

}
<style>
	.container-fluid {
		padding: 0px !important;
	}
</style>
@*End:Hidden*@