@page "/scheduler/event-actions-button"

@using Syncfusion.Blazor.Schedule
@using System.Globalization
@*Hidden:Lines*@
@inherits SampleBaseComponent
@inject IJSRuntime JSRuntime
@*End:Hidden*@
<ActionDescription>
    <p>
        This demo showcases the event action buttons for editing and deleting events in day and week views. Click the edit or delete icons to manage your events.
    </p>
    <p>
        In this demo, we have implemented custom event templates with action buttons for each event displayed in the Scheduler. These action buttons allow users to edit or delete events directly from the event cells. When the Edit button is clicked, the event editor is opened using the <code>OpenEditorAsync</code> method. When the Delete button is clicked, the selected event is removed using the <code>DeleteEventAsync</code> method.
    </p>
    <p>Looking for the full Blazor Scheduler component overview, features, pricing, and documentation? Visit our <a rel="noopener" target='_blank' href='https://www.syncfusion.com/blazor-components/blazor-scheduler' aria-label="Navigate to the Blazor Scheduler FT page">Blazor Scheduler</a> component page.</p>
</ActionDescription>

<div id="wrapper" class="control-section action-button">
    <div class="component-wrapper" style="display: flex">
        <div class="main-content">
            <SfSchedule TValue="ScheduleData.AppointmentData" Height="650px" @bind-SelectedDate="@CurrentDate" @ref="ScheduleRef" @bind-CurrentView="@CurrentView">
                <ScheduleEvents TValue="ScheduleData.AppointmentData" OnPopupOpen="OnPopupOpen" EventRendered="OnEventRendered"></ScheduleEvents>
                <ScheduleViews>
                    <ScheduleView Option="View.Day"></ScheduleView>
                    <ScheduleView Option="View.Week"></ScheduleView>
                </ScheduleViews>
                <ScheduleEventSettings DataSource="@EventDataSource">
                    <Template>
                        @{
                            if (context is ScheduleData.AppointmentData eventData)
                            {
                                <div class="custom-event">
                                    <div class="event-content">
                                        <span class="event-title">@eventData.Subject</span>
                                    </div>
                                    <div class="event-actions">
                                        <!-- Edit Button -->
                                        <button class="icon-btn"
                                                @onclick:stopPropagation
                                                @onclick="(() => EditEvent(eventData))">
                                            <span class="e-icons e-edit"></span>
                                        </button>
                                        <!-- Delete Button -->
                                        <button class="icon-btn"
                                                @onclick:stopPropagation
                                                @onclick="(() => DeleteEvent(eventData))">
                                            <span class="e-icons e-trash"></span>
                                        </button>
                                    </div>
                                </div>
                                <div class="time">Time: @(eventData.StartTime.ToString("HH:mm", CultureInfo.InvariantCulture)) - @((eventData.EndTime).ToString("HH:mm", CultureInfo.InvariantCulture))</div>
                            }
                        }

                    </Template>
                </ScheduleEventSettings>
            </SfSchedule>
        </div>
    </div>
</div>

@code {
    private SfSchedule<ScheduleData.AppointmentData>? ScheduleRef;
    private View CurrentView { get; set; } = View.Week;
    private List<ScheduleData.AppointmentData> EventDataSource = new ScheduleData().GetZooEventData();
    private DateTime CurrentDate { get; set; } = new DateTime(DateTime.Today.Year, 1, 16);
    // Edit
    private async Task EditEvent(ScheduleData.AppointmentData data)
    {
        if (ScheduleRef == null)
        {
            return;
        }
        await ScheduleRef.OpenEditorAsync(data, CurrentAction.Save);
    }

    // Delete
    private async Task DeleteEvent(ScheduleData.AppointmentData data)
    {
        if (ScheduleRef == null)
        {
            return;
        }
        await ScheduleRef.DeleteEventAsync(data);
    }
    public void OnPopupOpen(PopupOpenEventArgs<ScheduleData.AppointmentData> args)
    {
        if (args.Type == PopupType.QuickInfo && args.Data.Id != 0)
        {
            args.Cancel = true;
        }
    }
    public void OnEventRendered(EventRenderedArgs<ScheduleData.AppointmentData> args)
    {
        var categoryColor = args.Data?.CategoryColor ?? string.Empty;
        args.Attributes = ScheduleData.ApplyCategoryColor(categoryColor, args.Attributes, CurrentView);
    }
}
<style>
    .custom-event {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 100%;
        padding: 2px 4px;
        overflow: hidden;
        width: 100%;
    }

    .event-content {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .event-title {
        font-size: 12px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .time {
        text-wrap: auto;
    }

    .event-actions {
        display: flex;
        gap: 4px;
        padding: 4px;
    }

    /* Icon button styling */
    .icon-btn {
        background: transparent;
        border: none;
        padding: 2px;
        cursor: pointer;
    }

        .icon-btn .e-icons {
            font-size: 12px;
        }

    .e-schedule .e-vertical-view .e-all-day-appointment-wrapper .e-appointment .time {
        display: none;
    }

    /* Mobile responsiveness */
    @@media (max-width: 768px) {
        .event-title {
            font-size: 10px;
        }

        .icon-btn .e-icons {
            font-size: 10px;
        }

        .event-actions {
            gap: 2px;
            padding: 0px;
        }

        .custom-event {
            display: contents;
        }
    }
</style>