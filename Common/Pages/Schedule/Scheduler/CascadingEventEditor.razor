@page "/scheduler/cascading-event-editor"

@using Syncfusion.Blazor.Schedule
@using Syncfusion.Blazor.Calendars
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Inputs
@*Hidden:Lines*@
@inherits SampleBaseComponent
@*End:Hidden*@

<ActionDescription>
<p>
    This demo showcases the Cascading Event Editor in the Blazor Scheduler. Editor fields dynamically update based on user selections, enabling guided input, improving accuracy, and enhancing usability for complex scheduling scenarios.
  </p>
  <p>
    This example demonstrates a <strong>Cascading Event Editor</strong> built with the Blazor Scheduler component. It enhances the default editor by introducing dependent fields that blazor to user input, creating a more structured and efficient event creation experience.
  </p>
  <p><strong>Cascading Dropdowns</strong></p>
  <p>
    Dropdown selections dynamically filter related fields, ensuring users only see relevant options. This reduces clutter and simplifies the form interaction.
  </p>
  <p>
    <strong>Improved Data Consistency</strong>
  </p>
  <p>
    Field dependencies enforce logical relationships, minimizing invalid entries and maintaining clean, structured data—ideal for hierarchical scenarios like resources, categories, or services.
  </p>
  <p>
    <strong>Flexible Customization</strong>
  </p>
  <p>
    The editor layout is fully customizable, allowing integration of custom inputs, validation, and UI enhancements to match specific business needs.
  </p>
  <p><strong>Key Benefits</strong></p>
  <p>
    This approach simplifies data entry, reduces errors, and boosts productivity through intelligent field interactions—making it well-suited for advanced scheduling and booking applications.
  </p>
  <p>Looking for the full Blazor Scheduler component overview, features, pricing, and documentation? Visit our <a rel="noopener" target='_blank' href='https://www.syncfusion.com/blazor-components/blazor-scheduler' aria-label="Navigate to the Blazor Scheduler FT page">Blazor Scheduler</a> component page.</p>
</ActionDescription>


<div class="col-lg-12 control-section">
    <SfSchedule TValue="AppointmentData" @ref="scheduleObj" CssClass="custom-scheduler" Width="100%" Height="600px" @bind-SelectedDate="@CurrentDate">
        <ScheduleEvents TValue="AppointmentData" EventRendered="OnEventRendered"></ScheduleEvents>
        <ScheduleGroup Resources="@Resources"></ScheduleGroup>
        <ScheduleResources>
            <ScheduleResource TItem="ResourceData" TValue="int" DataSource="@StaffData" Field="StaffId" Title="Staff" Name="Staff" TextField="Text" IdField="Id" GroupIDField="StaffId" ColorField="Color"></ScheduleResource>
        </ScheduleResources>
        <ScheduleEventSettings DataSource="@DataSource"></ScheduleEventSettings>
        <ScheduleViews>
            <ScheduleView Option="View.TimelineDay"></ScheduleView>
        </ScheduleViews>
        <ScheduleTemplates>
            <HeaderIndentTemplate>
                <div class="template-wrap header-indent">
                    <div>Staff</div>
                    <div>Type</div>
                </div>
            </HeaderIndentTemplate>
            <ResourceHeaderTemplate Context="data">
                @{
                    var resourceData = (data as Syncfusion.Blazor.Schedule.TemplateContext)?.ResourceData as ResourceData;
                }
                <div class="template-wrap">
                    <div>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <div style="width: 32px; height: 32px; border-radius: 50%; background-color: @(resourceData?.Color ?? "#666"); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">
                                @(resourceData != null && !string.IsNullOrEmpty(resourceData.Text) ? resourceData.Text.Substring(0, 1) : string.Empty)
                            </div>
                            <div>@(resourceData?.Text ?? string.Empty)</div>
                        </div>
                    </div>
                    <div>@(resourceData?.Type ?? string.Empty)</div>
                </div>
            </ResourceHeaderTemplate>
            <EditorTemplate>
            @{
                var _appt = context as AppointmentData ?? new AppointmentData();
            }
            <table class="custom-event-editor" width="100%" cellpadding="5">
                <tbody>
                    <tr>
                        <td class="e-textlabel">Name</td>
                        <td colspan="4">
                            <SfTextBox @bind-Value="@(_appt.Subject)"></SfTextBox>
                        </td>
                    </tr>
                    <tr>
                        <td class="e-textlabel">Type</td>
                        <td colspan="4">
                            <SfDropDownList TValue="string" TItem="DDFields" DataSource="@TaskData" Placeholder="Choose status" @bind-Value="@_appt.Type">
                                <DropDownListFieldSettings Value="Id" Text="Text"></DropDownListFieldSettings>
                            </SfDropDownList>
                        </td>
                    </tr>
                    @if (_appt.Type == "Meeting")
                    {
                        <tr>
                            <td class="e-textlabel">Floor</td>
                            <td colspan="4">
                                <SfDropDownList TValue="int" TItem="FloorDataFields" DataSource="@FloorData" @bind-Value="@(_appt.FloorId)">
                                    <DropDownListFieldSettings Value="Id" Text="Name"></DropDownListFieldSettings>
                                </SfDropDownList>
                            </td>
                        </tr>
                        <tr>
                            <td class="e-textlabel">Room</td>
                            <td colspan="4">
                                <SfDropDownList TValue="int" TItem="RoomDataFields" DataSource="@RoomData" @bind-Value="@(_appt.RoomId)">
                                    <DropDownListFieldSettings Value="Id" Text="Name"></DropDownListFieldSettings>
                                </SfDropDownList>
                            </td>
                        </tr>
                    }
                    <tr>
                        <td class="e-textlabel">Resource</td>
                        <td colspan="4">
                            <SfDropDownList TValue="int" TItem="ResourceData" DataSource="@StaffData" @bind-Value="@(_appt.StaffId)">
                                <DropDownListFieldSettings Value="Id" Text="Text"></DropDownListFieldSettings>
                            </SfDropDownList>
                        </td>
                    </tr>
                    <tr>
                        <td class="e-textlabel">Start</td>
                        <td colspan="4">
                            <SfDateTimePicker @bind-Value="@(_appt.StartTime)"></SfDateTimePicker>
                        </td>
                    </tr>
                    <tr>
                        <td class="e-textlabel">End</td>
                        <td colspan="4">
                            <SfDateTimePicker @bind-Value="@(_appt.EndTime)"></SfDateTimePicker>
                        </td>
                    </tr>
                </tbody>
            </table>
        </EditorTemplate>
        </ScheduleTemplates>
    </SfSchedule>
</div>

@code{
    SfSchedule<AppointmentData>? scheduleObj;
    DateTime CurrentDate = new DateTime(2026, 5, 11);
    public string[] Resources { get; set; } = { "Staff" };
    public void OnEventRendered(EventRenderedArgs<AppointmentData> args)
    {
        if (args.Data == null)
        {
            return;
        }

        var color = args.Data.Type switch
        {
            "Appointment" => "#357cd2",
            "Internal" => "#f57f17",
            "Meeting" => "#1aaa55",
            _ => "#7fa900",
        };

        args.Attributes = new Dictionary<string, object>()
        {
            { "style", $"background-color:{color};" }
        };
    }
    public List<ResourceData> StaffData { get; set; } = new List<ResourceData>
    {
        new ResourceData { Text = "Mike Anderson", Id = 1, StaffId = 1, Color = "#1aaa55", Type = "Consultants" },
        new ResourceData { Text = "Kevin Larson", Id = 2, StaffId = 2, Color = "#357cd2", Type = "Sales" },
        new ResourceData { Text = "Sarah Johnson", Id = 3, StaffId = 3, Color = "#f57f17", Type = "Sales" },
        new ResourceData { Text = "David Miller", Id = 4, StaffId = 4, Color = "#7fa900", Type = "Testers" },
        new ResourceData { Text = "Emma Wilson", Id = 5, StaffId = 5, Color = "#df5286", Type = "Testers" }
    };
    List<AppointmentData> DataSource = new List<AppointmentData>
    {
        new AppointmentData { Id = 1, Subject = "Meeting", Type = "Meeting", StartTime = new DateTime(2026, 5, 11, 9, 0, 0), EndTime = new DateTime(2026, 5, 11, 12, 0, 0), StaffId = 2, FloorId = 1, RoomId = 102 },
        new AppointmentData { Id = 2, Subject = "Appointment", Type = "Appointment", StartTime = new DateTime(2026, 5, 11, 10, 0, 0), EndTime = new DateTime(2026, 5, 11, 12, 0, 0), StaffId = 2, FloorId = 1, RoomId = 102 },
        new AppointmentData { Id = 3, Subject = "Review", Type = "Internal", StartTime = new DateTime(2026, 5, 11, 10, 0, 0), EndTime = new DateTime(2026, 5, 11, 13, 0, 0), StaffId = 3, FloorId = 2, RoomId = 101 },
        new AppointmentData { Id = 4, Subject = "Discussion", Type = "Meeting", StartTime = new DateTime(2026, 5, 11, 13, 0, 0), EndTime = new DateTime(2026, 5, 16, 14, 0, 0), StaffId = 4, FloorId = 1, RoomId = 101 },
        new AppointmentData { Id = 5, Subject = "Planning", Type = "Meeting", StartTime = new DateTime(2026, 5, 11, 11, 0, 0), EndTime = new DateTime(2026, 5, 11, 15, 0, 0), StaffId = 5, FloorId = 2, RoomId = 101 },
        new AppointmentData { Id = 6, Subject = "Planning", Type = "Internal", StartTime = new DateTime(2026, 5, 11, 13, 0, 0), EndTime = new DateTime(2026, 5, 11, 15, 0, 0), StaffId = 1, FloorId = 2, RoomId = 101 },
    };
    List<DDFields> TaskData = new List<DDFields>() {
        new DDFields(){ Id= "Meeting", Text= "Meeting" },
        new DDFields(){ Id= "Appointment", Text= "Appointment" },
        new DDFields(){ Id= "Internal", Text= "Internal" },
    };
    private List<FloorDataFields> FloorData = new List<FloorDataFields>
    {
        new FloorDataFields { Id = 1, Name = "Floor 1" },
        new FloorDataFields { Id = 2, Name = "Floor 2" }
    };
    private List<RoomDataFields> RoomData = new List<RoomDataFields>
    {
        new RoomDataFields { Id = 1, Name = "Room 101" },
        new RoomDataFields { Id = 2, Name = "Room 102" }
    };
    public class AppointmentData
    {
        public int Id { get; set; }
        public string? Subject { get; set; }
        public string Location { get; set; } = string.Empty;
        public DateTime StartTime { get; set; }
        public DateTime EndTime { get; set; }
        public string Description { get; set; } = string.Empty;
        public bool IsAllDay { get; set; }
        public string? RecurrenceRule { get; set; }
        public string RecurrenceException { get; set; } = string.Empty;
        public Nullable<int> RecurrenceID { get; set; }
        public int StaffId { get; set; }
        public int FloorId { get; set; }
        public int RoomId { get; set; }
        public string Type { get; set; } = "Meeting";
    }
    public class ResourceData
    {
        public int Id { get; set; }
        public string? Text { get; set; }
        public string? Color { get; set; }
        public int StaffId { get; set; }
        public string? Type { get; set; }
    }
    public class DDFields
    {
        public string? Id { get; set; }
        public string? Text { get; set; }
    }
    public class FloorDataFields
    {
        public int Id { get; set; }
        public string? Name { get; set; }
    }
    public class RoomDataFields
    {
        public int Id { get; set; }
        public string? Name { get; set; }
    }
}
