@page "/scheduler/task-progress-tracker"
@using Syncfusion.Blazor.Schedule
@using Syncfusion.Blazor.Calendars
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Inputs
@using taskprogresstracker.Data
@inject NavigationManager UriHelper
@inherits SampleBaseComponent

<ActionDescription>
  <p>
    This demo showcases an advanced task progress tracker in the Scheduler with elegant event customization, vibrant status indicators, real-time progress visualization, and interactive editing. Track and manage team task assignments with visual status icons and completion percentage indicators.
  </p>
  <p>
    The Task Progress Tracker displays team tasks with a refined visual design. Each event shows the task subject on the left and completion percentage on the right, while the status indicator icon is positioned at the bottom left with a colored background matching the task status.
  </p>
  <p><b>Status Tracking</b></p>
  <p>
    Tasks are displayed with visual status indicators: clock icon for pending tasks, play icon for in-progress work, eye icon for tasks under review, and checkmark icon for completed tasks. Each status has a distinct color for quick visual identification.
  </p>
  <p><b>Progress Visualization</b></p>
  <p>
    Each event displays the completion percentage in real-time. The progress indicator updates dynamically as tasks advance through different status states.
  </p>
  <p><b>Interactive Editing</b></p>
  <p>
    Edit task details directly from the Scheduler using the editor. Customize task status and progress percentage with automatic validation rules ensuring data consistency based on the selected status.
  </p>
  <p>Looking for the full Blazor Scheduler component overview, features, pricing, and documentation? Visit our <a rel="noopener" target='_blank' href='https://www.syncfusion.com/blazor-components/blazor-scheduler' aria-label="Navigate to the Blazor Scheduler FT page">Blazor Scheduler</a> component page.</p>
</ActionDescription>


<div class="schedule-control-section task-progress-control-section">
    <div class="col-lg-12 control-section">
        <div class="content-wrapper task-progress-tracker-sample-wrapper">
            <SfSchedule TValue="TaskProgressTrackerData" @ref="ScheduleRef" CssClass="event-customization-schedule" Width="100%" Height="550px" @bind-SelectedDate="@CurrentDate" StartHour="08:00" EndHour="18:00" ShowWeekend="false" AllowOverlap="false">
                <ScheduleGroup Resources="@Resources"></ScheduleGroup>  
                <ScheduleResources>
                    <ScheduleResource TItem="ResourceData" TValue="int[]" DataSource="@EmployeeData" Field="EmployeeId" Title="Employee" Name="Employees" TextField="Text" IdField="Id" ColorField="Color"></ScheduleResource>
                </ScheduleResources>
                <ScheduleTemplates>
                    <EditorTemplate>
                    @{
                        var con = context as TaskProgressTrackerData ?? new TaskProgressTrackerData();
                        if (con != null)
                        {
                            var s = string.IsNullOrEmpty(con.StatusType) ? "pending" : con.StatusType.ToLowerInvariant();
                            if (s == "pending")
                            {
                                if (!con.Progress.HasValue) con.Progress = 0;
                            }
                            else if (s == "in-progress")
                            {
                                if (!con.Progress.HasValue) con.Progress = 0;
                                if (con.Progress > 98) con.Progress = 98;
                            }
                            else if (s == "review")
                            {
                                con.Progress = 99;
                            }
                            else if (s == "done")
                            {
                                con.Progress = 100;
                            }
                        }
                        <table class="custom-event-editor" width="100%" cellpadding="5">
                            <tbody>
                                <tr>
                                    <td colspan="4">
                                        <SfTextBox ID="@nameof(TaskProgressTrackerData.Subject)" CssClass="e-field e-input" @bind-Value="@con!.Subject" Placeholder="Title" FloatLabelType="FloatLabelType.Always"></SfTextBox>
                                    </td>
                                    <td colspan="4">
                                        <SfTextBox ID="@nameof(TaskProgressTrackerData.Location)" CssClass="e-field e-input" @bind-Value="@(con.Location)" Placeholder="Location" FloatLabelType="FloatLabelType.Always"></SfTextBox>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="4">
                                        <SfDateTimePicker ID="@nameof(TaskProgressTrackerData.StartTime)" CssClass="e-field" TValue="DateTime" @bind-Value=con.StartTime Placeholder="Start" FloatLabelType="FloatLabelType.Always"></SfDateTimePicker>
                                    </td>
                                    <td colspan="4">
                                        <SfDateTimePicker ID="@nameof(TaskProgressTrackerData.EndTime)" CssClass="e-field" TValue="DateTime" @bind-Value=con.EndTime Placeholder="End" FloatLabelType="FloatLabelType.Always"></SfDateTimePicker>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="4">
                                        <SfDropDownList TValue="int" TItem="ResourceData" ID="EmployeeId" DataSource="@EmployeeData" Placeholder="Choose Employee" FloatLabelType="FloatLabelType.Always" @bind-Value="@(con.EmployeeId)">
                                            <DropDownListFieldSettings Text="Text" Value="Id"></DropDownListFieldSettings>
                                        </SfDropDownList>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="8">
                                            <SfTextBox ID="@nameof(TaskProgressTrackerData.Description)" CssClass="e-field e-input" @bind-Value="@con.Description" Placeholder="Description" FloatLabelType="FloatLabelType.Always" Multiline="true"></SfTextBox>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="8">
                                        <SfDropDownList ID="StatusType" TValue="string" TItem="DDFields" DataSource="@StatusData" Placeholder="Choose status" FloatLabelType="FloatLabelType.Always" @bind-Value="@(con.StatusType)">
                                            <DropDownListFieldSettings Text="Text" Value="Id"></DropDownListFieldSettings>
                                            <DropDownListEvents TValue="string" TItem="DDFields" ValueChange="@((ChangeEventArgs<string, DDFields> args) => OnStatusChanged(args.Value, con))"></DropDownListEvents>
                                        </SfDropDownList>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="8">
                                        <SfNumericTextBox TValue="int?" Placeholder="Progress (%)" FloatLabelType="FloatLabelType.Always"
                                            Value="@(con.Progress)"
                                            Readonly="@(IsReadonlyStatus(con.StatusType))"
                                            Min="0"
                                            Max="@(GetProgressMax(con.StatusType))">
                                        </SfNumericTextBox>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    }
                    </EditorTemplate>
                </ScheduleTemplates>
                <ScheduleEventSettings DataSource="@taskData">
                    <ScheduleField Id="Id" IsBlock="IsDisabled">
                        <FieldSubject Name="Subject"></FieldSubject>
                        <FieldDescription Name="Description"></FieldDescription>
                        <FieldStartTime Name="StartTime"></FieldStartTime>
                        <FieldEndTime Name="EndTime"></FieldEndTime>
                    </ScheduleField>
                </ScheduleEventSettings>
                <ScheduleViews>
                    <ScheduleView Option="View.TimelineWeek">
                        <EventTemplate>
                        @{
                            if (context is TaskProgressTrackerData appointment)
                            {
                                var status = string.IsNullOrEmpty(appointment.StatusType) ? "pending" : appointment.StatusType.ToLowerInvariant();
                                var config = StatusMap.ContainsKey(status) ? StatusMap[status] : StatusMap["pending"];
                                var progressText = $"{appointment.Progress}%";
                                <div class="custom-event" data-status="@status.ToLower()" style="--status-color:@config.Color;" title="@(!string.IsNullOrEmpty(appointment.Subject) ? appointment.Subject : "Task")">
                                    <div class="event-header">
                                        <div class="event-subject">@(!string.IsNullOrEmpty(appointment.Subject) ? appointment.Subject : "Task")</div>
                                        <div class="event-progress-percent">@progressText</div>
                                    </div>
                                    <div class="event-footer">
                                        <div class="label-wrapper">
                                            <span class="e-icons @config.Icon status-icon"></span>
                                            <span class="status-label">@status</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        </EventTemplate>
                    </ScheduleView>
                </ScheduleViews>  
            </SfSchedule>
        </div>
    </div>
</div>
@code {
    private SfSchedule<TaskProgressTrackerData>? ScheduleRef;
    DateTime CurrentDate = new DateTime(2026, 4, 24);
    public List<TaskProgressTrackerData> taskData { get; set; } = new List<TaskProgressTrackerData>();
    protected override void OnInitialized()
    {
        taskData = TaskProgressTrackerData.GetTaskData().ToList();
        base.OnInitialized();
    }
    public string[] Resources { get; set; } = { "Employees" };
    int? GetProgressMax(string status)
    {
        if (string.IsNullOrEmpty(status)) return 100;
        return status.ToLowerInvariant() switch
        {
            "pending" => 98,
            "in-progress" => 98,
            "review" => 99,
            "done" => 100,
            _ => 100
        };
    }
    bool IsReadonlyStatus(string status)
    {
        if (string.IsNullOrEmpty(status)) return false;
        var s = status.ToLowerInvariant();
        return s == "review" || s == "done" || s == "pending";
    }
    void OnStatusChanged(string newStatus, TaskProgressTrackerData appt)
    {
        if (appt == null) return;
        appt.StatusType = newStatus;
        var s = (newStatus ?? string.Empty).ToLowerInvariant();
        if (s == "review") appt.Progress = 99;
        else if (s == "done") appt.Progress = 100;
        else if (s == "pending") appt.Progress = 0;
        else if (s == "in-progress")
            appt.Progress = 98;
    }
    void OnProgressChanged(int? progress, TaskProgressTrackerData appt)
    {
        if (appt == null) return;
        appt.Progress = progress;
        var currentStatus = (appt.StatusType ?? string.Empty).ToLowerInvariant();
        if (progress.HasValue)
        {
            if (progress == 100 && currentStatus != "done")
            {
                appt.StatusType = "done";
            }
            else if (progress >= 99 && progress < 100 && currentStatus != "review")
            {
                appt.StatusType = "review";
            }
            else if (progress > 0 && progress < 99 && currentStatus != "in-progress")
            {
                appt.StatusType = "in-progress";
            }
            else if (progress == 0 && currentStatus != "pending")
            {
                appt.StatusType = "pending";
            }
        }
        StateHasChanged();
    }
    List<DDFields> StatusData = new List<DDFields>() {
        new DDFields(){ Id= "pending", Text= "Pending" },
        new DDFields(){ Id= "in-progress", Text= "In-Progress" },
        new DDFields(){ Id= "review", Text= "Review" },
        new DDFields(){ Id= "done", Text= "Done" },
    };
    public List<ResourceData> EmployeeData { get; set; } = new()
    {
        new ResourceData{ Text = "Sarah", Id = 1, Color = "#EF4444" },
        new ResourceData{ Text = "John", Id = 2, Color = "#10B981" },
        new ResourceData{ Text = "Emma", Id = 3, Color = "#3B82F6" },
        new ResourceData{ Text = "Michael", Id = 4, Color = "#F59E0B" },
        new ResourceData{ Text = "Lisa", Id = 5, Color = "#8B5CF6" },
        new ResourceData{ Text = "David", Id = 6, Color = "#EC4899" }
    };
    private readonly Dictionary<string, (string Icon, string Color)> StatusMap = new()
    {
        ["pending"] = ("e-clock", "#DC2626"),
        ["in-progress"] = ("e-play", "#3B82F6"),
        ["review"] = ("e-eye", "#F59E0b"),
        ["done"] = ("e-check", "#10B981")
    };
    public class DDFields
    {
        public string? Id { get; set; }
        public string? Text { get; set; }
    }
    public class ResourceData
    {
        public int Id { get; set; }
        public string Text { get; set; } = string.Empty;
        public string Color { get; set; } = string.Empty;
    }
}

<style>
.event-customization-schedule.e-schedule .e-appointment .e-appointment-details {
    height: 100%;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
    display: flex;
}

.event-customization-schedule.e-schedule .e-event-resize.e-right-handler {
    background: #F3F4F6 !important;
}

.event-customization-schedule.e-schedule .custom-event {
    background: #F3F4F6;
    height: 100%;
    width: 100%;
    box-shadow: none;
    padding: 2px 8px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    overflow: hidden;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

.event-customization-schedule.e-schedule .custom-event .event-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 4px;
    width: 100%;
    padding: 1px 0;
}

.event-customization-schedule.e-schedule .custom-event .event-header .event-subject {
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 11px;
    font-weight: 600;
    color: #1F2937;
    line-height: 1.1;
}

.event-customization-schedule.e-schedule .custom-event .event-header .event-progress-percent {
    background: rgba(0, 0, 0, 0.5);
    padding: 1px 4px;
    border-radius: 2px;
    color: #fff;
    font-weight: 700;
    font-size: 9px;
    white-space: nowrap;
    flex-shrink: 0;
}

.event-customization-schedule.e-schedule .custom-event .event-footer {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 3px;
    width: 100%;
    line-height: 1;
    padding: 0;
}

.event-customization-schedule.e-schedule .custom-event .event-footer .label-wrapper{
    color: #ffffff;
    padding: 2px 4px;
    border-radius: 2px;
    display: flex;
    align-items: center;
    gap: 2px;
    font-size: 8px;
    font-weight: 500;
}

.event-customization-schedule.e-schedule .custom-event[data-status="pending"] .event-footer .label-wrapper {
    background-color: #DC2626;
}

.event-customization-schedule.e-schedule .custom-event[data-status="in-progress"] .event-footer .label-wrapper {
    background-color: #3b82f6;
}

.event-customization-schedule.e-schedule .custom-event[data-status="review"] .event-footer .label-wrapper {
    background-color: #f59e0b;
}

.event-customization-schedule.e-schedule .custom-event[data-status="done"] .event-footer .label-wrapper {
    background-color: #10b981;
}

.event-customization-schedule.e-schedule .custom-event .event-footer .label-wrapper .status-icon {
    flex-shrink: 0;
}

.event-customization-schedule.e-schedule .custom-event .event-footer .label-wrapper .status-label {
    text-transform: capitalize;
    letter-spacing: 0.5px;
}

.event-customization-schedule.e-schedule .e-timeline-view .e-resource-left-td {
    width: 150px;
}

.event-customization-schedule.e-schedule .e-timeline-view .e-date-header-wrap table col,
.event-customization-schedule.e-schedule .e-timeline-view .e-content-wrap table col {
    width: 90px;
}

.e-field-group.e-custom-row {
    margin-top: 16px;
}

.event-customization-schedule.e-schedule .e-timeline-view .e-appointment, 
.event-customization-schedule.e-schedule .e-timeline-month-view .e-appointment {
    border-radius: 5px;
}
table.custom-event-editor,
table.custom-event-editor td,
table.custom-event-editor th {
   padding: 5px;
}

table.custom-event-editor .e-field {
    height: 36px;
}
</style>