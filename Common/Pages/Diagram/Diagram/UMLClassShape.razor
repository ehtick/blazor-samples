    private SymbolInfo GetSymbolInfo(IDiagramObject symbol)
    {
        string? description = symbol is Node ? (symbol as Node)!.ID : (symbol as Connector)!.ID;

            SymbolInfo.Description = new SymbolDescription()
            {
                Text = description,
                Style = new TextStyle()
                {
                    TextOverflow = TextOverflow.Wrap, FontSize = 10
                },
            };
        return SymbolInfo;
    }
    
    private void OnCollectionChanging(CollectionChangingEventArgs args)
    {
        if (args.Action == CollectionChangedAction.Add && args.Element != null)
        {
            if ((Diagram!.SelectionSettings!.Nodes!.Count > 0) && Diagram.SelectionSettings.Nodes[0].Shape is UmlClassifierShape umlClassifierShape)
            {
                TextStyle style = new TextStyle { Fill = "#E3F2FD", StrokeColor = "#1976D2", Bold = true, Color = "#0D47A1" };
                if (umlClassifierShape.Classifier != ClassifierShape.Enumeration)
                {
                    UmlClass? umlClassShape = umlClassifierShape.Classifier == ClassifierShape.Class ? umlClassifierShape.ClassShape : umlClassifierShape.InterfaceShape as UmlClass;
                    if (umlClassShape != null)
                    {
                        if (args.Element is UmlClassAttribute attribute)
                        {
                            if (umlClassShape.Attributes.Count > 0)
                            {
                                style = (umlClassShape.Attributes[0].Style.Clone() as TextStyle)!;
                            }
                            attribute.Style = style!;
                        }
                        else if (args.Element is UmlClassMethod method)
                        {
                            if (umlClassShape.Methods.Count > 0)
                            {
                                style = (umlClassShape.Methods[0].Style.Clone() as TextStyle)!;
                            }
                            method.Style = style!;
                        }
                    }
                }
                else if (args.Element is UmlEnumerationMember member)
                {
                    member.Style = new TextStyle { Fill = "#E3F2FD", StrokeColor = "#1976D2", Bold = true, Color = "#0D47A1" };
                }
            }
        }
    }

    [Inject]
    protected IJSRuntime? jsRuntime { get; set; }
    public async Task ShowHideSymbolPalette()
    {
        await jsRuntime!.InvokeAsync<object>("openPalette");
    }

    @*Hidden:Lines*@
    public void Dispose()
    {
        if (nodes != null)
        {
            nodes.Clear();
            nodes = null;
        }
        if (connectors != null)
        {
            connectors.Clear();
            connectors = null;
        }
    }
    @*End:Hidden*@
