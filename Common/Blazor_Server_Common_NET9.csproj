<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <LangVersion>13.0</LangVersion>
    <RootNamespace>BlazorDemos</RootNamespace>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <EnableMSDeployAppOffline>true</EnableMSDeployAppOffline>
    <DefineConstants>SERVER</DefineConstants>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <CompressionExcludePatterns>
      $(CompressionExcludePatterns);styles/component-samples/**
    </CompressionExcludePatterns>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <SupportedPlatform Include="browser" />
  </ItemGroup>
  <ItemGroup>
    <PagesFile Include="wwwroot/scripts/**/*.js" />
    <PagesFile Include="Pages/**" />
    <PagesFile Include="Model/**" />
  </ItemGroup>
  <Target Name="ShipPages" BeforeTargets="BeforeBuild">
    <Copy SourceFiles="@(PagesFile)" DestinationFiles="wwwroot\scripts\Pages\%(RecursiveDir)%(Filename)%(Extension).txt" />
  </Target>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <DefineConstants>TRACE;RELEASE;NET9_0;$(SyncfusionLicensing);STAGING;SERVER</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <DefineConstants>TRACE;DEBUG;NET9_0;STAGING;SERVER;BUILD_ENV</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(STAGING)' != ''">
    <DefineConstants>$(DefineConstants);STAGING</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(ISSTAGING)' != ''">
    <DefineConstants>$(DefineConstants);ISSTAGING</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Blazored.FluentValidation" Version="2.2.0" />
    <PackageReference Include="Markdig" Version="0.44.0" />
    <PackageReference Include="Syncfusion.Blazor.AI" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.SmartComponents" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Buttons" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Cards" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.DataForm" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Spinner" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.BarcodeGenerator" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.CircularGauge" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.LinearGauge" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Notifications" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Popups" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.SplitButtons" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Layouts" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Inputs" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Calendars" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Navigations" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Diagram" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.DropDowns" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.RichTextEditor" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.SmartRichTextEditor" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.ImageEditor" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.QueryBuilder" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Schedule" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Kanban" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Grid" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.MultiColumnComboBox" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.TreeGrid" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Gantt" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.TreeMap" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.FileManager" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.HeatMap" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.InPlaceEditor" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Maps" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.ProgressBar" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Charts" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.RangeNavigator" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.StockChart" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.BulletChart" Version="34.1.29" />
