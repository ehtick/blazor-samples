    <PackageReference Include="Syncfusion.Blazor.ChartWizard" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Sankey" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Licensing" Version="34.1.29" />
