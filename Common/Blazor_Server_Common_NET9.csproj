    <PackageReference Include="Syncfusion.Blazor.InteractiveChat" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.Ribbon" Version="34.1.29" />
    <PackageReference Include="Syncfusion.Blazor.BlockEditor" Version="34.1.29" />
